# ============================================================
# LOCAL DEVELOPMENT (Docker SQL Server)
# ============================================================
# MSSQL_HOST=sqlserver
# MSSQL_PORT=1433
# MSSQL_DB=InteractHubDb
# MSSQL_SA_PASSWORD=InteractHub@123A

# ============================================================
# PRODUCTION (Azure SQL Database)
# Lấy từ: Azure Portal → SQL Database → Connection strings → ADO.NET
# Thay {your_password} bằng password thực
# ============================================================
ConnectionStrings__DefaultConnection=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=InteractHubDb;User ID=sqladmin;Password={your_password};MultipleActiveResultSets=True;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# JWT
JwtSettings__SecretKey=replace_with_minimum_32_chars_secret
JwtSettings__Issuer=InteractHub
JwtSettings__Audience=InteractHub
JwtSettings__ExpirationInMinutes=60

# CORS (comma-separated if multiple origins)
AllowedOrigins=http://localhost:5173,https://interact-hub.jackethee.dev

# ASP.NET
ASPNETCORE_ENVIRONMENT=Production

# Azure Blob Storage
AzureBlobStorage__ConnectionString=DefaultEndpointsProtocol=https;AccountName=your_account;AccountKey=your_key;EndpointSuffix=core.windows.net
AzureBlobStorage__ContainerName=uploads